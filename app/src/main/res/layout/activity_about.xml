<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/aboutToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="About"
        app:titleTextColor="@android:color/white"
        app:navigationIconTint="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <!-- App Name & Version Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/app_name"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/versionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp" />

            <!-- ==========================================
                 Important Notice Card
                 ========================================== -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/notice_bg"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Important Notice"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SmartFind is a personal phone-finder for locating misplaced devices around your home, office, or nearby surroundings. It is not an anti-theft or security tool.\n\nIf your phone is stolen, use Google Find My Device (google.com/android/find) which offers remote lock, erase, and real-time tracking. SmartFind does not replace that functionality."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==========================================
                 Privacy Section
                 ========================================== -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacy"
                style="@style/SectionHeader"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Privacy First"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SmartFind operates entirely offline and never connects to the internet. All your data \u2014 designated contacts, trigger keyword, and settings \u2014 is stored encrypted on your device using Android\u0027s hardware-backed keystore. No analytics, no tracking, no cloud services."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==========================================
                 Instructions Section
                 ========================================== -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instructions"
                style="@style/SectionHeader"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <!-- Quick Setup Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quick Setup"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add trusted contacts using \u0022+ Add Number\u0022. Set your trigger keyword (default: FIND, case sensitive, exact match). Turn on the service toggle. Authentication is required for all configuration changes."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Trigger Keyword Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trigger Keyword"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The exact message a contact sends via SMS to activate SmartFind. The entire SMS must be only the keyword \u2014 no extra words, punctuation, or other text. Case sensitive, minimum 3 characters. For example, if your keyword is FIND, the contact must send exactly \u0022FIND\u0022 \u2014 messages like \u0022FIND my phone\u0022 or \u0022Please FIND\u0022 will not trigger the alarm. Change it anytime on the main screen."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Designated Contacts Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Designated Contacts"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="People who can trigger SmartFind by texting the keyword. Picked from your phone\u0027s contacts. Reconfirmed every 6 months. Adding or removing contacts requires biometric/PIN authentication."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Alarm Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alarm"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plays at maximum volume even on silent or vibrate. Suppressed during phone calls and Android Auto for safety. Reduced to current volume with no loop when battery is low. Stop it from the app or the notification. Use \u0022Test Alarm\u0022 to preview."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==========================================
                 Safety Features Section
                 ========================================== -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Safety Features"
                style="@style/SectionHeader"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Reception Outage Protection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reception Outage Protection"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="If your phone loses cellular reception for more than 1 minute, SmartFind enters a 2-minute grace period once signal is restored. During this window, SMS triggers show a notification instead of sounding the alarm, preventing false alarms from messages queued by the carrier while your phone had no signal."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="20dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_stroke"
                        android:layout_marginBottom="20dp" />

                    <!-- Active Use Protection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Use Protection"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Triggers are suppressed when the phone is unlocked and the screen is on, since the phone is clearly not lost."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="20dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_stroke"
                        android:layout_marginBottom="20dp" />

                    <!-- Trigger Cooldown -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trigger Cooldown"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="After stopping an alarm, new triggers are ignored for a configurable period to prevent repeated unwanted alarms. Set the duration in Settings."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="20dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_stroke"
                        android:layout_marginBottom="20dp" />

                    <!-- Car Mode Protection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Android Auto Protection"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="When Android Auto or a car dock is active, the loud alarm is suppressed for driving safety. A silent notification is shown instead."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="20dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_stroke"
                        android:layout_marginBottom="20dp" />

                    <!-- Phone Call Protection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phone Call Protection"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="When you are on an active phone call, the loud alarm is suppressed to avoid interrupting your conversation. A silent notification is shown instead."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="20dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_stroke"
                        android:layout_marginBottom="20dp" />

                    <!-- Low Battery Protection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Low Battery Protection"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="When battery is at or below 15%, the alarm plays at the current volume (not max) and does not loop to conserve power.\n\nWhen Android battery saver is on, the real-time SMS broadcast receiver is disabled by Android to save battery, so SmartFind relies entirely on the polling fallback. SMS detection may be delayed by up to the polling interval (default 3 minutes). Turning off battery saver restores instant detection within one polling cycle."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="20dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_stroke"
                        android:layout_marginBottom="20dp" />

                    <!-- Lock Screen Privacy -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lock Screen Privacy"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notifications on the lock screen hide contact names and numbers. Full details are shown only when the device is unlocked."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==========================================
                 Security Section
                 ========================================== -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Security"
                style="@style/SectionHeader"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Authentication -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Authentication"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Biometric or PIN/pattern/password authentication is required to add or remove contacts, toggle the service, and change safety settings. This prevents unauthorized changes to your SmartFind configuration."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="20dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_stroke"
                        android:layout_marginBottom="20dp" />

                    <!-- Rate Limiting -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rate Limiting"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SmartFind limits triggers to 5 per hour (sliding window). This protects against abuse even if a designated contact repeatedly sends trigger messages. Works alongside the per-alarm cooldown timer."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="20dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_stroke"
                        android:layout_marginBottom="20dp" />

                    <!-- Service Toggle -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Service Toggle"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Turns SMS monitoring on or off. When on, SmartFind listens in real time with a configurable backup check (default 3 minutes). A persistent notification shows when monitoring is active. All events are logged in an audit trail."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ==========================================
                 Legal Section
                 ========================================== -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Legal"
                style="@style/SectionHeader"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/card_background"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disclaimer"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SmartFind is provided \u0022as is\u0022 without warranty of any kind, express or implied. The developer makes no guarantees regarding the reliability, accuracy, or timeliness of SMS delivery, alarm triggering, or any other functionality. SmartFind depends on your mobile carrier and cellular reception for SMS delivery, which may be delayed or fail entirely. The developer shall not be liable for any damages arising from the use or inability to use this application. Use SmartFind at your own risk."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
